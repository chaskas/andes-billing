<% content_for :title, "Edit Recipient" %>

<%= link_to recipients_path, class: "back-link" do %>
  <i class="bi bi-arrow-left"></i> Recipients
<% end %>

<div class="card-andes p-4">
  <div class="d-flex align-items-center justify-content-between mb-4">
    <h1 class="mb-0">Edit Recipient</h1>
    <%= button_to @recipient, method: :delete, class: "btn btn-andes-danger btn-andes-sm", data: { turbo_confirm: "Are you sure?" } do %>
      <i class="bi bi-trash"></i> Delete
    <% end %>
  </div>
  <%= render "form", recipient: @recipient %>
</div>
