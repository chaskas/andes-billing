<%= form_with(model: invoice, html: { class: "form-andes" }) do |form| %>
  <% if invoice.errors.any? %>
    <div class="alert-andes alert-andes--error mb-3">
      <strong><%= pluralize(invoice.errors.count, "error") %> prohibited this invoice from being saved:</strong>
      <ul class="mb-0 mt-1">
        <% invoice.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row mb-3">
    <div class="col">
      <%= form.label :issue_date, "Issue Date", class: "form-label" %>
      <%= form.date_field :issue_date, class: "form-control" %>
    </div>
    <div class="col-2">
      <%= form.label :number, class: "form-label" %>
      <%= form.number_field :number, class: "form-control" %>
    </div>
    <div class="col">
      <%= form.label :tax_rate, "Tax Rate", class: "form-label" %>
      <%= form.select :tax_rate, Billing::Invoice.tax_rates.keys.map { |tax_rate| [tax_rate.humanize, tax_rate] }, {}, class: "form-select" %>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col">
      <%= form.label :billing_issuer_id, "Issuer", class: "form-label" %>
      <%= form.select :billing_issuer_id, @issuers.map { |issuer| [issuer.name, issuer.id] }, { }, class: "form-select" %>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col">
      <%= form.label :billing_recipient_id, "Recipient", class: "form-label" %>
      <%= form.select :billing_recipient_id, @recipients.map { |recipient| [recipient.name, recipient.id] }, { }, class: "form-select" %>
    </div>
  </div>

  <div class="mt-4">
    <%= form.submit (invoice.persisted? ? "Save" : "Create"), class: "btn btn-andes" %>
    <%= link_to "Cancel", invoices_path, class: "btn btn-andes-outline ms-2" %>
  </div>
<% end %>
