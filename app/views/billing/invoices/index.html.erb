<% content_for :title, "Invoices" %>

<div class="page-header">
  <div class="d-flex align-items-baseline">
    <h1 class="page-header__title">Invoices</h1>
    <span class="page-header__count"><%= @invoices.size %> total</span>
  </div>
  <%= link_to new_invoice_path, class: "btn btn-andes" do %>
    <i class="bi bi-plus"></i> New Invoice
  <% end %>
</div>

<% if @invoices.any? %>
  <div class="card-andes">
    <table class="table-andes">
      <thead>
        <tr>
          <th>Invoice</th>
          <th>Recipient</th>
          <th class="text-center">Date</th>
          <th class="text-end">Total</th>
          <th class="text-center">Options</th>
        </tr>
      </thead>
      <tbody>
        <% @invoices.each do |invoice| %>
          <tr>
            <td><%= link_to "##{invoice.number} — #{invoice.issue_date.year}", invoice_path(invoice) %></td>
            <td><%= invoice.recipient.name %></td>
            <td class="text-center"><%= invoice.issue_date&.to_fs(:day_month_year) %></td>
            <td class="text-end"><%= number_to_currency(invoice.gross_total, unit: "€", separator: ",", delimiter: ".") %></td>
            <td class="text-center">
              <%= link_to invoice_path(invoice), class: "btn btn-andes-outline btn-andes-sm" do %>
                <i class="bi bi-eye"></i>
              <% end %>
              <%= link_to edit_invoice_path(invoice), class: "btn btn-andes-outline btn-andes-sm" do %>
                <i class="bi bi-pencil"></i>
              <% end %>
              <%= link_to "#", class: "btn btn-andes-outline btn-andes-sm pdf-download-btn",
                    data: {
                      invoice_id: invoice.id,
                      invoice_number: invoice.number,
                      invoice_year: invoice.issue_date.year
                    } do %>
                <i class="bi bi-file-pdf"></i>
              <% end %>
              <%= link_to invoice_path(invoice), data: { turbo_method: :delete, turbo_confirm: 'Are you sure?' }, class: "btn btn-andes-danger btn-andes-sm" do %>
                <i class="bi bi-trash"></i>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% else %>
  <div class="card-andes p-4">
    <div class="empty-state">
      <div class="empty-state__icon"><i class="bi bi-receipt"></i></div>
      <div class="empty-state__text">No invoices yet.</div>
      <%= link_to new_invoice_path, class: "btn btn-andes btn-andes-sm" do %>
        <i class="bi bi-plus"></i> Create Invoice
      <% end %>
    </div>
  </div>
<% end %>

<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.9.3/html2pdf.bundle.min.js"></script>
<script>
  function setupPdfButtons() {
    document.querySelectorAll('.pdf-download-btn').forEach(function(button) {
      button.removeEventListener('click', handlePdfButtonClick);
      button.addEventListener('click', handlePdfButtonClick);
    });
  }

  function handlePdfButtonClick(event) {
    event.preventDefault();

    const invoiceId = this.dataset.invoiceId;
    const invoiceNumber = this.dataset.invoiceNumber;
    const invoiceYear = this.dataset.invoiceYear;

    const iframe = document.createElement('iframe');
    iframe.style.width = '0';
    iframe.style.height = '0';
    iframe.style.position = 'absolute';
    iframe.style.top = '-9999px';
    document.body.appendChild(iframe);

    iframe.onload = function() {
      const invoiceWrapper = iframe.contentDocument.getElementById('invoice-wrapper');
      if (invoiceWrapper) {
        const clonedWrapper = invoiceWrapper.cloneNode(true);

        const options = {
          margin: 10,
          filename: `Invoice_${invoiceNumber}_${invoiceYear}.pdf`,
          image: { type: 'jpeg', quality: 0.98 },
          html2canvas: { scale: 2, useCORS: true },
          jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
        };

        html2pdf().from(clonedWrapper).set(options).save();

        setTimeout(function() {
          document.body.removeChild(iframe);
        }, 1000);
      }
    };

    iframe.src = `/billing/invoices/${invoiceId}`;
  }

  document.addEventListener('DOMContentLoaded', setupPdfButtons);
  document.addEventListener('turbo:load', setupPdfButtons);
  document.addEventListener('turbo:render', setupPdfButtons);
</script>
