<% content_for :title, "Items" %>

<div class="billing-section-header">
  <h2>Items</h2>
</div>

<% unless invoice_items.count > 0 %>
  <div class="card-andes p-4">
    <div class="empty-state">
      <div class="empty-state__icon"><i class="bi bi-list-check"></i></div>
      <div class="empty-state__text">No invoice items yet. Add items using the form above.</div>
    </div>
  </div>
<% else %>
  <div class="card-andes">
    <table class="table-andes">
      <thead>
      <tr>
        <th class="text-center">Date</th>
        <th class="text-center">Duration</th>
        <th class="text-center">Kind</th>
        <th>Description</th>
        <th class="text-end">Unit Price</th>
        <th class="text-center">Options</th>
      </tr>
      </thead>
      <tbody>

      <% invoice_items.sort_by { |i| i.date || Time.zone.now }.each do |item| %>
        <tr>
          <th class="text-center"><%= item.date&.to_fs(:day_month_year) %></th>
          <td class="text-center"><%= item.duration %></td>
          <td class="text-center"><%= item.kind %></td>
          <td><%= item.description %></td>
          <td class="text-end"><%= number_to_currency(item.unit_price, unit: "€", separator: ",", delimiter: ".") %></td>
          <td class="text-center">
            <% if item.id.present? %>
              <%= button_to billing.invoice_invoice_item_path(item.billing_invoice_id, item.id), method: :delete, class: "btn btn-andes-danger btn-andes-sm", form: { data: { turbo_stream: true } } do %>
                <i class="bi bi-trash"></i>
              <% end %>
            <% end %>
          </td>
        </tr>
      <% end %>

      </tbody>
    </table>
  </div>
<% end %>
