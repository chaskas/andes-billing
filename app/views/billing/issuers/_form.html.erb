<%= form_with(model: issuer, html: { class: "form-andes" }) do |form| %>
  <% if issuer.errors.any? %>
    <div class="alert-andes alert-andes--error mb-3">
      <strong><%= pluralize(issuer.errors.count, "error") %> prohibited this issuer from being saved:</strong>
      <ul class="mb-0 mt-1">
        <% issuer.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row mb-3">
    <div class="col-md-3">
      <%= form.label :tax_number, "Tax Number", class: "form-label" %>
      <%= form.text_field :tax_number, class: "form-control" %>
    </div>
    <div class="col">
      <%= form.label :name, class: "form-label" %>
      <%= form.text_field :name, class: "form-control" %>
    </div>
  </div>

  <div class="row mb-3">
    <div class="col-md-3">
      <%= form.label :phone, class: "form-label" %>
      <%= form.text_field :phone, class: "form-control" %>
    </div>
    <div class="col">
      <%= form.label :address, class: "form-label" %>
      <%= form.text_field :address, class: "form-control" %>
    </div>
  </div>

  <div class="mb-3">
    <%= form.label :email, class: "form-label" %>
    <%= form.text_field :email, class: "form-control" %>
  </div>

  <div class="mt-4">
    <%= form.submit (issuer.persisted? ? "Save" : "Create"), class: "btn btn-andes" %>
    <%= link_to "Cancel", issuers_path, class: "btn btn-andes-outline ms-2" %>
  </div>
<% end %>
