<% content_for :title, "Issuers" %>

<div class="page-header">
  <div class="d-flex align-items-baseline">
    <h1 class="page-header__title">Issuers</h1>
    <span class="page-header__count"><%= @issuers.size %> total</span>
  </div>
  <%= link_to new_issuer_path, class: "btn btn-andes" do %>
    <i class="bi bi-plus"></i> New Issuer
  <% end %>
</div>

<% if @issuers.any? %>
  <% @issuers.each do |issuer| %>
    <div class="list-card">
      <div class="list-card__info">
        <div class="list-card__title"><%= issuer.name %></div>
        <div class="list-card__meta">
          <i class="bi bi-hash"></i> <%= issuer.tax_number %>
          <% if issuer.phone.present? %>
            &middot; <i class="bi bi-telephone"></i> <%= issuer.phone %>
          <% end %>
          <% if issuer.email.present? %>
            &middot; <i class="bi bi-envelope"></i> <%= issuer.email %>
          <% end %>
        </div>
      </div>
      <div class="list-card__actions">
        <%= link_to edit_issuer_path(issuer), class: "btn btn-andes-outline btn-andes-sm" do %>
          <i class="bi bi-pencil"></i> Edit
        <% end %>
        <%= button_to issuer, method: :delete, class: "btn btn-andes-danger btn-andes-sm", data: { turbo_confirm: "Are you sure?" } do %>
          <i class="bi bi-trash"></i>
        <% end %>
      </div>
    </div>
  <% end %>
<% else %>
  <div class="card-andes p-4">
    <div class="empty-state">
      <div class="empty-state__icon"><i class="bi bi-building"></i></div>
      <div class="empty-state__text">No issuers yet.</div>
      <%= link_to new_issuer_path, class: "btn btn-andes btn-andes-sm" do %>
        <i class="bi bi-plus"></i> Add Issuer
      <% end %>
    </div>
  </div>
<% end %>
